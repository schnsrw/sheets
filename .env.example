# ─────────────────────────────────────────────────────────────────────────
# Casual Sheets — environment configuration.
#
# Copy to `.env` for `docker compose up` (compose auto-reads it) or
# pass through `--env-file .env` on `docker run`. None of these are
# required; defaults give a working single-user / in-memory setup.
#
# Vite-baked frontend knobs (VITE_*) only take effect on a fresh
# `pnpm --filter @sheet/web build` / `docker build` — they're not
# read at runtime by the browser.
# ─────────────────────────────────────────────────────────────────────────

# ─── Server (apps/server) ───────────────────────────────────────────────
# HTTP + WebSocket port the Fastify+Hocuspocus server listens on.
PORT=3000

# Bind address. `0.0.0.0` exposes to the network; `127.0.0.1` keeps
# it localhost-only.
HOST=0.0.0.0

# Redis connection string for Y.Doc persistence (optional). Unset =
# in-memory only; rooms vanish on restart. Set to enable 7-day TTL
# snapshot storage in Redis.
#   docker compose pattern:   REDIS_URL=redis://redis:6379
# REDIS_URL=

# How many minutes a room stays in memory after the LAST client
# disconnects. Lower = quicker eviction (less idle memory),
# higher = friendlier reconnect after a short drop.
ROOM_TTL_MIN=15

# Hard cap on multipart + raw-binary uploads to the server. Bounds
# the share-room seed (xlsx) and snapshot (gzipped JSON) upload
# paths. Raise this if your users open workbooks larger than the
# default — and bump `VITE_MAX_OPEN_MB` to match so the browser
# isn't permitted to upload something the server will 413.
MAX_UPLOAD_MB=100

# ─── Web build (apps/web) ───────────────────────────────────────────────
# Ship co-editing in the bundle. Off in the GitHub Pages demo build
# (single-user); on in the Docker image. Has no effect at runtime —
# this is consumed at `vite build` time.
VITE_COLLAB_ENABLED=1

# WebSocket URL the collab driver dials. Same-origin /yjs by default
# (works inside Docker). Override when running web on Vite dev
# (:5273) against a standalone server (:3000):
# VITE_COLLAB_WS_URL=ws://127.0.0.1:3000/yjs

# Hard reject for File → Open / drag-drop. Larger files freeze and
# eventually OOM-crash the tab during the ExcelJS parse — this is
# the ceiling, not a recommendation. The supported sweet spot is
# 25–50 MB.
VITE_MAX_OPEN_MB=100

# Threshold above which the loading overlay shows the up-front
# "this is a large workbook, may take 10+ s" hint. Should be ≤
# `VITE_MAX_OPEN_MB`.
VITE_SOFT_WARN_MB=25
